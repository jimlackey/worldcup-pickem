# ============================================================================
# World Cup Pick'em — Environment Variables
# Copy to .env.local and fill in values
# ============================================================================

# --- Supabase ---
# Project URL (from Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key — used for public reads (RLS-gated)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — NEVER expose to client. Used server-side for all writes.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Resend (email delivery) ---
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_...

# "From" address for OTP emails. Must be verified in Resend.
# Use a subdomain like noreply@pickem.yourdomain.com
# For development, Resend allows sending from onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Auth / Sessions ---
# Secret for signing session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=your-64-char-hex-secret-here

# Session duration in hours (default 72 = 3 days)
SESSION_DURATION_HOURS=72

# OTP expiry in minutes (default 10)
OTP_EXPIRY_MINUTES=10

# --- App ---
# Base URL for the app (used in OTP emails for links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default tournament ID (matches seed data)
NEXT_PUBLIC_TOURNAMENT_ID=00000000-0000-0000-0000-000000000001
